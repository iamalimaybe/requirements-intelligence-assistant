{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirements Trusted Context",
  "type": "object",
  "required": [
    "requirement_name",
    "summary",
    "known_facts",
    "required_unknowns",
    "client_questions",
    "required_backend_tasks",
    "required_frontend_tasks",
    "required_database_considerations",
    "required_test_cases",
    "required_hallucination_checks"
  ],
  "additionalProperties": true,
  "properties": {
    "requirement_name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "known_facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_unknowns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "client_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_backend_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task_item"
      }
    },
    "required_frontend_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task_item"
      }
    },
    "required_database_considerations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/database_item"
      }
    },
    "required_test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/test_case"
      }
    },
    "required_hallucination_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hallucination_check"
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "blocked",
        "optional"
      ]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "task_item": {
      "type": "object",
      "required": [
        "task",
        "status",
        "reason",
        "depends_on"
      ],
      "additionalProperties": true,
      "properties": {
        "task": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/depends_on"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "depends_on": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "database_item": {
      "type": "object",
      "required": [
        "item",
        "status",
        "reason",
        "depends_on"
      ],
      "additionalProperties": true,
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/depends_on"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "depends_on": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "test_case": {
      "type": "object",
      "required": [
        "name",
        "status",
        "given",
        "expected",
        "depends_on"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "given": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/depends_on"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "depends_on": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "hallucination_check": {
      "type": "object",
      "required": [
        "check",
        "result",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "check": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "warning",
            "blocked"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}