{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirements-analysis.schema.json",
  "title": "Requirements Analysis Output",
  "description": "Schema for structured software requirements analysis generated by a local LLM.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "facts_used",
    "unknowns",
    "client_questions",
    "backend_tasks",
    "frontend_tasks",
    "database_considerations",
    "test_cases",
    "hallucination_checks"
  ],
  "properties": {
    "facts_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "client_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "backend_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "frontend_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "database_considerations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/database_consideration"
      }
    },
    "test_cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/test_case"
      }
    },
    "hallucination_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hallucination_check"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "status", "reason", "depends_on"],
      "properties": {
        "task": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "blocked", "optional"]
        },
        "reason": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "database_consideration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item", "status", "reason", "depends_on"],
      "properties": {
        "item": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "blocked", "optional"]
        },
        "reason": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "test_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "given", "expected", "depends_on"],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "blocked", "optional"]
        },
        "given": {
          "type": "string"
        },
        "expected": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hallucination_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "result", "notes"],
      "properties": {
        "check": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "warning", "blocked"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}